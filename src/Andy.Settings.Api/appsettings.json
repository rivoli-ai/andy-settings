{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5438;Database=andy_settings;Username=andy_settings;Password=andy_settings_dev_password"
  },
  "Database": {
    "Provider": "PostgreSql"
  },
  "AndyAuth": {
    "Provider": "AndyAuth",
    "Authority": "https://localhost:5001",
    "Audience": "urn:andy-settings-api",
    "RequireHttpsMetadata": false
  },
  "Cors": {
    "Origins": [
      "https://localhost:5380",
      "https://localhost:4200",
      "https://localhost:3000"
    ]
  },
  "OpenTelemetry": {
    "_comment": "Legacy key; kept for backward compatibility. OT5 moved tracing/metrics config to AndyTelemetry below.",
    "ServiceName": "andy-settings-api",
    "OtlpEndpoint": ""
  },
  "AndyTelemetry": {
    "ServiceName": "andy-settings",
    "OtlpEndpoint": "",
    "Protocol": "http/protobuf"
  },
  "Rbac": {
    "ApiBaseUrl": "https://localhost:5003",
    "ApplicationCode": "settings"
  },
  "Messaging": {
    "Provider": "Nats",
    "Nats": {
      "Url": "nats://localhost:4222",
      "StreamName": "ANDY_DOMAIN",
      "StreamSubjects": [ "andy.settings.events.>" ],
      "DlqPrefix": "andy.settings.dlq"
    },
    "Outbox": {
      "PollInterval": "00:00:01",
      "BatchSize": 200,
      "BackoffBase": "00:00:01",
      "BackoffMax": "00:05:00"
    },
    "SeenMessages": {
      "PurgeInterval": "00:15:00",
      "PurgeBatchSize": 1000,
      "DefaultTtl": "90.00:00:00"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  }
}
